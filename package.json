{
  "name": "lightprint",
  "version": "0.0.1",
  "type": "module",
  "description": "A comprehensive React component library built on Radix UI and Tailwind CSS 4",
  "keywords": [
    "react",
    "components",
    "ui",
    "component-library",
    "design-system",
    "radix-ui",
    "tailwindcss",
    "typescript",
    "accessible"
  ],
  "author": "Saulo Vallory <saulo@vallory.dev> (https://vallory.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svallory/lightprint.git"
  },
  "homepage": "https://github.com/svallory/lightprint#readme",
  "bugs": {
    "url": "https://github.com/svallory/lightprint/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/lightprint.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lightprint.js"
    },
    "./inputs": {
      "types": "./dist/components/inputs/index.d.ts",
      "import": "./dist/inputs/index.js"
    },
    "./inputs/*": {
      "types": "./dist/components/inputs/*.d.ts",
      "import": "./dist/inputs/*.js"
    },
    "./feedback": {
      "types": "./dist/components/feedback/index.d.ts",
      "import": "./dist/feedback/index.js"
    },
    "./feedback/*": {
      "types": "./dist/components/feedback/*.d.ts",
      "import": "./dist/feedback/*.js"
    },
    "./overlay": {
      "types": "./dist/components/overlay/index.d.ts",
      "import": "./dist/overlay/index.js"
    },
    "./overlay/*": {
      "types": "./dist/components/overlay/*.d.ts",
      "import": "./dist/overlay/*.js"
    },
    "./navigation": {
      "types": "./dist/components/navigation/index.d.ts",
      "import": "./dist/navigation/index.js"
    },
    "./navigation/*": {
      "types": "./dist/components/navigation/*.d.ts",
      "import": "./dist/navigation/*.js"
    },
    "./layout": {
      "types": "./dist/components/layout/index.d.ts",
      "import": "./dist/layout/index.js"
    },
    "./layout/*": {
      "types": "./dist/components/layout/*.d.ts",
      "import": "./dist/layout/*.js"
    },
    "./data-display": {
      "types": "./dist/components/data-display/index.d.ts",
      "import": "./dist/data-display/index.js"
    },
    "./data-display/*": {
      "types": "./dist/components/data-display/*.d.ts",
      "import": "./dist/data-display/*.js"
    },
    "./typography": {
      "types": "./dist/components/typography/index.d.ts",
      "import": "./dist/typography/index.js"
    },
    "./typography/*": {
      "types": "./dist/components/typography/*.d.ts",
      "import": "./dist/typography/*.js"
    },
    "./hooks": {
      "types": "./dist/components/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./hooks/*": {
      "types": "./dist/components/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./styles": "./src/styles/globals.css"
  },
  "imports": {
    "#inputs": "./src/components/inputs/index.ts",
    "#inputs/*": "./src/components/inputs/*",
    "#feedback": "./src/components/feedback/index.ts",
    "#feedback/*": "./src/components/feedback/*",
    "#overlay": "./src/components/overlay/index.ts",
    "#overlay/*": "./src/components/overlay/*",
    "#navigation": "./src/components/navigation/index.ts",
    "#navigation/*": "./src/components/navigation/*",
    "#layout": "./src/components/layout/index.ts",
    "#layout/*": "./src/components/layout/*",
    "#data-display": "./src/components/data-display/index.ts",
    "#data-display/*": "./src/components/data-display/*",
    "#typography": "./src/components/typography/index.ts",
    "#typography/*": "./src/components/typography/*",
    "#hooks": "./src/components/hooks/index.ts",
    "#hooks/*": "./src/components/hooks/*"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic",
    "lint:package": "publint",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
